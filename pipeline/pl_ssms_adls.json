{
	"name": "pl_ssms_adls",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"description": "copying the data from ssms to azure data lake",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_ssms",
						"type": "DatasetReference",
						"parameters": {
							"source_schema": {
								"value": "@pipeline().parameters.source_schema",
								"type": "Expression"
							},
							"source_table": {
								"value": "@pipeline().parameters.source_table",
								"type": "Expression"
							},
							"databasename": {
								"value": "@pipeline().parameters.databasename",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_adls",
						"type": "DatasetReference",
						"parameters": {
							"filename": {
								"value": "@pipeline().parameters.sink_filename",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"source_schema": {
				"type": "string"
			},
			"source_table": {
				"type": "string"
			},
			"sink_filename": {
				"type": "string"
			},
			"databasename": {
				"type": "string"
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-03-06T05:09:38Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}